# ═══════════════════════════════════════════════════════════════
# Example: azmon-lawappinsights recipe
# cp terraform.tfvars.example terraform.tfvars  &&  edit values
# ═══════════════════════════════════════════════════════════════

agent_name          = "my-sre-agent"
resource_group_name = "rg-sre-agent"
location            = "eastus2"

target_resource_groups = [
  "rg-my-workload"
]

access_level             = "Low"
action_mode              = "Review"
upgrade_channel          = "Preview"
monthly_agent_unit_limit = 10000
default_model_provider   = "Anthropic"
default_model_name       = "Automatic"

tags = {
  environment = "dev"
  team        = "sre"
}

# ── Connector toggles ──

enable_app_insights_connector = true
app_insights_resource_id      = "/subscriptions/<SUB_ID>/resourceGroups/<RG>/providers/Microsoft.Insights/components/<AI_NAME>"
app_insights_app_id           = "<APP_INSIGHTS_GUID>"

enable_log_analytics_connector = true
law_resource_id                = "/subscriptions/<SUB_ID>/resourceGroups/<RG>/providers/Microsoft.OperationalInsights/workspaces/<LAW_NAME>"

enable_azure_monitor_connector = true
azure_monitor_lookback_days    = 7

# ── Identity (leave empty to create new UAMI) ──

existing_managed_identity_id = ""

# ── Extensions (optional — uncomment to add) ──

